+    from nosvoid_sim import Simulator, World, Entity, EntityKind, farm
+    from nosvoid_sim.grid import Grid
+    g = Grid.from_rows(["." * 40] * 40)
+    player = Entity(eid=0, kind=EntityKind.PLAYER, vnum=0, x=10, y=10,
